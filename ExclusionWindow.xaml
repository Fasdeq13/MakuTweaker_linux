<controls:MicaWindow x:Class="MakuTweakerNew.ExclusionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        mc:Ignorable="d"
        ui:ThemeManager.RequestedTheme="Default"
        Title="Исключения процессов"
        Height="430" Width="650" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        SystemBackdropType="Tabbed" 
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        FocusVisualStyle="{x:Null}"
        Focusable="False"
        Topmost="False"
        Icon="/assets/images/makut.png">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="InfoText"
           Text="Введите имена процессов через запятую:" 
           FontSize="18" Margin="0,0,0,10" FontWeight="SemiBold"
           TextWrapping="Wrap"/>

        <TextBox x:Name="ExclusionsTxt" Grid.Row="1" TextWrapping="Wrap" 
         AcceptsReturn="True" VerticalContentAlignment="Top" Padding="5"
         ui:ControlHelper.PlaceholderText="discord, spotify, cs2, chrome..."/>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom">
                <TextBlock x:Name="ProcessNameStyleLabel" Text="Формат имен процессов:" FontSize="18" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <RadioButton x:Name="RadioNameFriendly" Content="Дружелюбный (Microsoft Edge)" Margin="0,0,15,0"/>
                    <RadioButton x:Name="RadioNameSystem" Content="Системный (msedge.exe)" Margin="0,0,15,0"/>
                    <RadioButton x:Name="RadioNameBoth" Content="Оба варианта" />
                </StackPanel>
                <CheckBox x:Name="OnlyMbCheck" FontSize="13" Margin="0,0,0,0"/>
                <CheckBox x:Name="ReplaceTaskmgrCheck" FontSize="13" Margin="0,0,0,0"/>
            </StackPanel>
            <Button x:Name="SaveBtn" Content="Сохранить" Padding="20,4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="Save_Click"/>
        </Grid>
    </Grid>
</controls:MicaWindow>