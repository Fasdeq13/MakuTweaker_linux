<Page x:Class="MakuTweakerNew.SysAndRec"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MakuTweakerNew"
      xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      mc:Ignorable="d" d:DesignWidth="704.04" d:DesignHeight="1412"
      Title="System and Recovery">

    <Grid Grid.IsSharedSizeScope="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
            <StackPanel>
                <TextBlock x:Name="label" HorizontalAlignment="Left" Margin="24,11,0,0" TextWrapping="Wrap" Text="System and Recovery" VerticalAlignment="Top" FontSize="32" FontFamily="Segoe UI Semibold"/>

                <StackPanel Orientation="Horizontal" Margin="24,10,0,0">
                    <TextBlock x:Name="sfclabel" Text="Repair System Using SFC" FontSize="16" VerticalAlignment="Center"/>
                    <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                        <controls:Button.ToolTip>
                            <ToolTip MaxWidth="500" x:Name="sys_tooltip_sfc"/>
                        </controls:Button.ToolTip>
                    </controls:Button>
                </StackPanel>

                <Grid HorizontalAlignment="Left" Margin="24,5,0,0" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SysRecButtons"/>
                    </Grid.ColumnDefinitions>
                    <controls:Button x:Name="sfc" Padding="20,5" Content="Repair" Height="28" Click="sfc_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="24,10,0,0">
                    <TextBlock x:Name="dismlabel" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Repair System Using DISM" VerticalAlignment="Center" FontSize="16"/>
                    <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                        <controls:Button.ToolTip>
                            <ToolTip MaxWidth="500" x:Name="sys_tooltip_dism"/>
                        </controls:Button.ToolTip>
                    </controls:Button>
                </StackPanel>

                <Grid HorizontalAlignment="Left" Margin="24,5,0,0" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SysRecButtons"/>
                    </Grid.ColumnDefinitions>
                    <controls:Button x:Name="dism" Padding="20,5" Content="Repair" Height="28" Click="dism_Click"/>
                </Grid>

                <TextBlock x:Name="templabel" HorizontalAlignment="Left" Margin="24,10,0,0" TextWrapping="Wrap" Text="Clean TEMP Folder" VerticalAlignment="Top" FontSize="16"/>

                <Grid HorizontalAlignment="Left" Margin="24,5,0,0" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SysRecButtons"/>
                    </Grid.ColumnDefinitions>
                    <controls:Button x:Name="temp" Padding="20,5" Content="Clean" Height="28" Click="temp_Click"/>
                </Grid>

                <TextBlock x:Name="batterylabel" HorizontalAlignment="Left" Margin="24,10,0,0" TextWrapping="Wrap" Text="Make a Report of The Battery Characteristics" VerticalAlignment="Top" FontSize="16"/>

                <Grid HorizontalAlignment="Left" Margin="24,5,0,0" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SysRecButtons"/>
                    </Grid.ColumnDefinitions>
                    <controls:Button x:Name="report" Padding="20,5" Content="Report" Height="28" Click="report_Click" />
                </Grid>

                <StackPanel Margin="24,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Header, ElementName=sticky}" FontSize="16" VerticalAlignment="Center"/>
                        <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                            <controls:Button.ToolTip>
                                <ToolTip MaxWidth="500" x:Name="sys_tooltip_sticky"/>
                            </controls:Button.ToolTip>
                        </controls:Button>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="sticky" FontSize="16" Header="Disable Sticky Keys" Toggled="sticky_Toggled">
                        <ui:ToggleSwitch.HeaderTemplate>
                            <DataTemplate />
                        </ui:ToggleSwitch.HeaderTemplate>
                    </ui:ToggleSwitch>
                </StackPanel>

                <StackPanel Margin="24,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Header, ElementName=coreisol}" FontSize="16" VerticalAlignment="Center"/>
                        <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                            <controls:Button.ToolTip>
                                <ToolTip MaxWidth="500" x:Name="sys_tooltip_coreisol"/>
                            </controls:Button.ToolTip>
                        </controls:Button>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="coreisol" FontSize="16" Header="Disable Core Isolation / Memory Integrity" Toggled="coreisol_Toggled">
                        <ui:ToggleSwitch.HeaderTemplate>
                            <DataTemplate />
                        </ui:ToggleSwitch.HeaderTemplate>
                    </ui:ToggleSwitch>
                </StackPanel>

                <StackPanel Margin="24,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Header, ElementName=uac}" FontSize="16" VerticalAlignment="Center"/>
                        <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                            <controls:Button.ToolTip>
                                <ToolTip MaxWidth="500" x:Name="sys_tooltip_uac"/>
                            </controls:Button.ToolTip>
                        </controls:Button>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="uac" FontSize="16" Header="Disable User Account Control" Toggled="uac_Toggled">
                        <ui:ToggleSwitch.HeaderTemplate>
                            <DataTemplate />
                        </ui:ToggleSwitch.HeaderTemplate>
                    </ui:ToggleSwitch>
                </StackPanel>

                <StackPanel Margin="24,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Header, ElementName=smartscreen}" FontSize="16" VerticalAlignment="Center"/>
                        <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                            <controls:Button.ToolTip>
                                <ToolTip MaxWidth="500" x:Name="sys_tooltip_smartscreen"/>
                            </controls:Button.ToolTip>
                        </controls:Button>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="smartscreen" FontSize="16" Header="Disable SmartScreen" Toggled="smartscreen_Toggled">
                        <ui:ToggleSwitch.HeaderTemplate>
                            <DataTemplate />
                        </ui:ToggleSwitch.HeaderTemplate>
                    </ui:ToggleSwitch>
                </StackPanel>

                <ui:ToggleSwitch x:Name="sleeptimeout" Header="Disable Sleep Timeout" FontSize="16" Toggled="sleeptimeout_Toggled" VerticalAlignment="Top" Margin="24,10,0,0"/>

                <StackPanel Margin="24,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Header, ElementName=bing}" FontSize="16" VerticalAlignment="Center"/>
                        <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                            <controls:Button.ToolTip>
                                <ToolTip MaxWidth="500" x:Name="sys_tooltip_bing"/>
                            </controls:Button.ToolTip>
                        </controls:Button>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="bing" FontSize="16" Header="Disable Online Search in Start Menu via Bing" Toggled="bing_Toggled">
                        <ui:ToggleSwitch.HeaderTemplate>
                            <DataTemplate />
                        </ui:ToggleSwitch.HeaderTemplate>
                    </ui:ToggleSwitch>
                </StackPanel>

                <StackPanel Margin="24,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Header, ElementName=chkdsk}" FontSize="16" VerticalAlignment="Center"/>
                        <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                            <controls:Button.ToolTip>
                                <ToolTip MaxWidth="500" x:Name="sys_tooltip_chkdsk"/>
                            </controls:Button.ToolTip>
                        </controls:Button>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="chkdsk" FontSize="16" Header="Set Chkdsk Timeout to 1 Minute" Toggled="chkdsk_Toggled">
                        <ui:ToggleSwitch.HeaderTemplate>
                            <DataTemplate />
                        </ui:ToggleSwitch.HeaderTemplate>
                    </ui:ToggleSwitch>
                </StackPanel>

                <StackPanel Margin="24,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Header, ElementName=bitlocker}" FontSize="16" VerticalAlignment="Center"/>
                        <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                            <controls:Button.ToolTip>
                                <ToolTip MaxWidth="500" x:Name="sys_tooltip_bitlocker"/>
                            </controls:Button.ToolTip>
                        </controls:Button>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="bitlocker" FontSize="16" Header="Disable BitLocker Automatic Encryption" Toggled="bitlocker_Toggled">
                        <ui:ToggleSwitch.HeaderTemplate>
                            <DataTemplate />
                        </ui:ToggleSwitch.HeaderTemplate>
                    </ui:ToggleSwitch>
                </StackPanel>

                <ui:ToggleSwitch x:Name="telemetry" Header="Disable All Telemetry" Margin="24,10,0,0" VerticalAlignment="Top" FontSize="16" Toggled="telemetry_Toggled"/>

                <StackPanel Margin="24,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Header, ElementName=hybern}" FontSize="16" VerticalAlignment="Center"/>
                        <controls:Button Content="?" Width="18" Height="18" Margin="8,0,0,0" FontSize="12" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                            <controls:Button.ToolTip>
                                <ToolTip MaxWidth="500" x:Name="sys_tooltip_hyber"/>
                            </controls:Button.ToolTip>
                        </controls:Button>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="hybern" FontSize="16" Header="Disable Hibernation" Toggled="hybern_Toggled" Margin="0,0,0,15">
                        <ui:ToggleSwitch.HeaderTemplate>
                            <DataTemplate />
                        </ui:ToggleSwitch.HeaderTemplate>
                    </ui:ToggleSwitch>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>