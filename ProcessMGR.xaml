<Page x:Class="MakuTweakerNew.ProcessMGR"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d" d:DesignHeight="702" d:DesignWidth="704"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded"
      Focusable="True">

    <Page.Resources>
        <ContextMenu x:Key="ItemContextMenu" Opened="ContextMenu_Opened" Closed="ContextMenu_Closed">
            <MenuItem Header="Завершить процесс" Click="KillProcess_Click">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="Cancel"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="AddToExclMenu" Header="Добавить в исключения" Click="AddToExclusions_Click">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="UnPin"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Расположение файла" Click="OpenLocation_Click">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="Folder"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="MemoryProgressStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="2"/>
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorLight2Brush}"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="label" Margin="15,11,0,10" FontSize="32" FontFamily="Segoe UI Semibold" Text="ProcessMGR"/>

                <controls:Button x:Name="buttontooltip" FocusVisualStyle="{x:Null}" Width="26" Height="26" MinWidth="0" Padding="0" Margin="10,10,0,0" VerticalAlignment="Center" Click="InfoBtn_Click">
                    <ui:SymbolIcon x:Name="InfoIcon" Symbol="Help" FontSize="12"/>
                    <controls:Button.ToolTip>
                        <ToolTip MaxWidth="350" x:Name="mgr_tooltip"/>
                    </controls:Button.ToolTip>
                </controls:Button>

                <controls:Button x:Name="restartBtn" FocusVisualStyle="{x:Null}" Width="26" Height="26" Margin="5,10,0,0" VerticalAlignment="Center" Click="restartBtn_Click">
                    <ui:SymbolIcon Symbol="Refresh" FontSize="12"/>
                    <controls:Button.ToolTip>
                        <ToolTip MaxWidth="350" x:Name="mgr_upd_tooltip"/>
                    </controls:Button.ToolTip>
                </controls:Button>

                <controls:Button x:Name="PauseBtn" FocusVisualStyle="{x:Null}" Width="26" Height="26" Margin="5,10,0,0" VerticalAlignment="Center" Click="PauseBtn_Click">
                    <ui:SymbolIcon x:Name="PauseIcon" Symbol="Pause" FontSize="12"/>
                    <controls:Button.ToolTip>
                        <ToolTip MaxWidth="350" x:Name="mgr_pause_tooltip"/>
                    </controls:Button.ToolTip>
                </controls:Button>

                <controls:Button x:Name="topmost" FocusVisualStyle="{x:Null}" Width="26" Height="26" Margin="5,10,0,0" VerticalAlignment="Center" Click="TopmostBtn_Click">
                    <ui:SymbolIcon x:Name="TopmostIcon" Symbol="Pin" FontSize="12"/>
                    <controls:Button.ToolTip>
                        <ToolTip MaxWidth="350" x:Name="mgr_pin_tooltip"/>
                    </controls:Button.ToolTip>
                </controls:Button>

                <controls:Button x:Name="SettingsBtn" FocusVisualStyle="{x:Null}" Width="26" Height="26" Margin="5,10,0,0" VerticalAlignment="Center" Click="SettingsBtn_Click">
                    <ui:SymbolIcon Symbol="Setting" FontSize="12"/>
                    <controls:Button.ToolTip>
                        <ToolTip MaxWidth="350" x:Name="mgr_set_tooltip"/>
                    </controls:Button.ToolTip>
                </controls:Button>

                <controls:Button x:Name="MakuYan" FocusVisualStyle="{x:Null}" Height="26" Margin="5,10,0,0" Padding="8,0" VerticalAlignment="Center" Click="MakuYan_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:FontIcon x:Name="MakuYanIcon" Glyph="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,1,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="MakuYanText" Text="AppBlock" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </controls:Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" x:Name="ContentHost">
            <Grid x:Name="MainContent" Margin="12,0,24,12">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="MainTransform"/>
                </Grid.RenderTransform>

                <Border Background="#06FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="20,13,20,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="14"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="groupproc" Text="Process" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                           x:Name="groupmem" Text="Memory Usage" HorizontalAlignment="Left" Margin="10,0,0,0" TextAlignment="Right" FontSize="13" FontWeight="SemiBold"/>
                            <Border Grid.ColumnSpan="4" BorderBrush="#10FFFFFF" BorderThickness="0,0,0,1" Margin="-20,25,-20,0"/>
                        </Grid>

                        <ListView x:Name="ProcessListView" Grid.Row="1" Margin="2,0,2,0" 
                        Background="Transparent" BorderThickness="0"
                        ScrollViewer.VerticalScrollBarVisibility="Visible"
                        Tag="{Binding IsChecked, ElementName=CompactViewCheck}"
                        KeyDown="ProcessListView_KeyDown" MouseDoubleClick="ProcessListView_MouseDoubleClick" SelectionMode="Extended">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Margin" Value="0,5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=Tag}" Value="True">
                                                        <Setter Property="Margin" Value="0,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding Icon}" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Width" Value="20"/>
                                                        <Setter Property="Height" Value="20"/>
                                                        <Setter Property="Margin" Value="0,0,12,0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=Tag}" Value="True">
                                                                <Setter Property="Width" Value="14"/>
                                                                <Setter Property="Height" Value="14"/>
                                                                <Setter Property="Margin" Value="0,0,8,0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="14"/>
                                        </StackPanel>

                                        <Grid Grid.Column="1" MinWidth="120" MaxWidth="220" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="10,0,10,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="{Binding MemoryUsage}" FontSize="13" HorizontalAlignment="Left" TextAlignment="Left" TextTrimming="CharacterEllipsis"/>

                                            <ProgressBar Grid.Row="1" Value="{Binding MemoryPercentage}" Maximum="100">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar" BasedOn="{StaticResource MemoryProgressStyle}">
                                                        <Setter Property="Margin" Value="0,4,0,0"/>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=Tag}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>
                                        </Grid>

                                        <Button Grid.Column="2" Content="✕" Click="KillProcess_Click" Background="#15FFFFFF" BorderThickness="0" HorizontalAlignment="Center" Margin="0,0,-10,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                    <Setter Property="Height" Value="24"/>
                                                    <Setter Property="Width" Value="24"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="FontSize" Value="10"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=Tag}" Value="True">
                                                            <Setter Property="Height" Value="20"/>
                                                            <Setter Property="Width" Value="20"/>
                                                            <Setter Property="FontSize" Value="9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="MinHeight" Value="12"/>
                                    <Setter Property="Padding" Value="15,0"/>
                                    <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=Tag}" Value="True">
                                            <Setter Property="MinHeight" Value="20"/>
                                            <Setter Property="Padding" Value="15,0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <Border Grid.Row="2" BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="15,12" Background="#03FFFFFF" CornerRadius="0,0,8,8">
                            <StackPanel x:Name="ControlPanel" Orientation="Horizontal">
                                <ComboBox x:Name="MemoryLimitCombo" FocusVisualStyle="{x:Null}" SelectedIndex="3" FontSize="13" Margin="0,0,15,0" 
                                          SelectionChanged="FilterChanged"
                                          DropDownOpened="MemoryLimitCombo_DropDownOpened"
                                          DropDownClosed="MemoryLimitCombo_DropDownClosed"
                                          BorderThickness="0">
                                    <ComboBoxItem Content="All (0 MB)" Tag="0"/>
                                    <ComboBoxItem Content="From 50 MB" Tag="52428800"/>
                                    <ComboBoxItem Content="From 100 MB" Tag="104857600"/>
                                    <ComboBoxItem Content="From 300 MB" Tag="314572800"/>
                                    <ComboBoxItem Content="From 500 MB" Tag="524288000"/>
                                    <ComboBoxItem Content="From 1 GB" Tag="1073741824"/>
                                    <ComboBoxItem Content="From 2 GB" Tag="2147483648"/>
                                </ComboBox>
                                <CheckBox x:Name="GroupProcessesCheck" Content="Group identical" FontSize="13" VerticalAlignment="Center" Checked="FilterChanged" Unchecked="FilterChanged" Margin="0,0,20,0"/>
                                <CheckBox x:Name="CompactViewCheck" Content="Compact view" FontSize="13" VerticalAlignment="Center" Checked="FilterChanged" Unchecked="FilterChanged" Margin="0,0,20,0"/>
                                <CheckBox x:Name="OnlyNotRespondingCheck" Content="Show only frozen" FontSize="13" VerticalAlignment="Center" Checked="FilterChanged" Unchecked="FilterChanged" Margin="0,0,20,0"/>
                                <CheckBox x:Name="AutoStartCheck" Content="AutoStart" FontSize="13" VerticalAlignment="Center" Checked="AutoStart_Changed" Unchecked="AutoStart_Changed" Margin="0,0,20,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer x:Name="HelpContent" Visibility="Collapsed" Margin="12,0,12,12" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.RenderTransform>
                    <TranslateTransform x:Name="HelpTransform" Y="600"/>
                </ScrollViewer.RenderTransform>

                <TextBlock x:Name="HelpText" HorizontalAlignment="Left" FontSize="18" LineHeight="22" Margin="4,0,12,10" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>